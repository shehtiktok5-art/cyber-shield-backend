# Application Settings
APP_NAME=CYBER-SHIELD Backend
DEBUG=False
DEMO_MODE=True
ENVIRONMENT=production

# Database - PostgreSQL
DATABASE_URL=postgresql://cybershield:password@postgres:5432/cybershield
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=False

# Database - Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Database - Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Threat Intelligence APIs
MISP_URL=http://misp:80
MISP_API_KEY=test-api-key
OTX_API_KEY=your-otx-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
SHODAN_API_KEY=your-shodan-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Suricata IDS Integration
SURICATA_ENABLED=False
SURICATA_EVE_LOG_PATH=/var/log/suricata/eve.json
SURICATA_UNIX_SOCKET=/var/run/suricata/suricata-command.socket
SURICATA_CONFIG_PATH=/etc/suricata/suricata.yaml

# Zeek Integration
ZEEK_ENABLED=False
ZEEK_LOG_DIR=/var/log/zeek

# Network Monitoring
PACKET_CAPTURE_ENABLED=False
PACKET_CAPTURE_INTERFACE=eth0
PACKET_CAPTURE_FILTER=tcp or udp

# ML Model Settings
ML_MODEL_PATH=./models
ML_TRAINING_ENABLED=False
ML_BATCH_SIZE=32
ML_EPOCHS=10
ML_LOOKBACK_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
PROMETHEUS_METRICS_ENABLED=True
PROMETHEUS_PORT=8001

# Security
ENABLE_HTTPS=False

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Data Retention
DATA_RETENTION_DAYS=90
ALERT_RETENTION_DAYS=180
INCIDENT_RETENTION_DAYS=365
